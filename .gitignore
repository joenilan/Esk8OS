# PlatformIO build output + downloaded libraries
.pio/

# VS Code (keep extensions.json; ignore machine-specific bits)
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Node tooling for font generation
node_modules/

# Python font-tool caches
__pycache__/
*.pyc

# Generated design previews (regenerate with `python preview.py`)
/preview*.png

# Auto-generated firmware version header (stamped from version.txt + git state)
src/version.h

# Manual local backups
*.bak

# secrets + release staging + scratch
.env.raspi
release/
cfg.json
cfg_put.json

# local scratch: serial captures, reference shots, research notes
# (kept out of git so `git status --porcelain` stays clean — gen_version.py
# stamps builds -dirty whenever anything untracked is present)
scripts/_s*.txt
/diagram.png
/master-vesc.png
/slave-vesc.png
/theme-example.png
/image.png
/Esk8OS Evee research report*.md
